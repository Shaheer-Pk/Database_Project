<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.amusementpark.MainController"
            styleClass="root-pane"
            prefWidth="1280" prefHeight="800">

    <!-- ── LEFT SIDEBAR ──────────────────────────────────────────────────── -->
    <left>
        <VBox styleClass="sidebar" prefWidth="230" spacing="4">
            <padding><Insets top="0" right="0" bottom="16" left="0"/></padding>

            <!-- Logo / App name -->
            <VBox styleClass="sidebar-header" alignment="CENTER">
                <padding><Insets top="28" right="16" bottom="28" left="16"/></padding>
                <Label text="🎡" style="-fx-font-size: 32px;"/>
                <Label text="APEX PARK" styleClass="sidebar-app-name"/>
                <Label text="Admin Console" styleClass="sidebar-app-sub"/>
            </VBox>

            <Separator styleClass="sidebar-divider"/>

            <!-- Nav items — fx:id used by controller to set active state -->
            <VBox spacing="2" style="-fx-padding: 10 8 0 8;" VBox.vgrow="ALWAYS">
                <Button fx:id="navDashboard"
                        text="  📊   Dashboard"
                        styleClass="nav-btn, nav-btn-active"
                        maxWidth="Infinity"
                        onAction="#showDashboard"/>

                <Label text="HUMAN RESOURCES" styleClass="nav-section-label">
                    <VBox.margin><Insets top="16" bottom="2"/></VBox.margin>
                </Label>
                <Button fx:id="navStaff"
                        text="  👤   Staff"
                        styleClass="nav-btn"
                        maxWidth="Infinity"
                        onAction="#showStaff"/>

                <Label text="OPERATIONS" styleClass="nav-section-label">
                    <VBox.margin><Insets top="16" bottom="2"/></VBox.margin>
                </Label>
                <Button fx:id="navRides"
                        text="  🎢   Rides"
                        styleClass="nav-btn"
                        maxWidth="Infinity"
                        onAction="#showRides"/>
                <Button fx:id="navBowling"
                        text="  🎳   Bowling"
                        styleClass="nav-btn"
                        maxWidth="Infinity"
                        onAction="#showBowling"/>
                <Button fx:id="navCinema"
                        text="  🎬   Cinema"
                        styleClass="nav-btn"
                        maxWidth="Infinity"
                        onAction="#showCinema"/>

                <Label text="CUSTOMERS" styleClass="nav-section-label">
                    <VBox.margin><Insets top="16" bottom="2"/></VBox.margin>
                </Label>
                <Button fx:id="navCRM"
                        text="  💳   CRM"
                        styleClass="nav-btn"
                        maxWidth="Infinity"
                        onAction="#showCRM"/>

                <Label text="VENDORS" styleClass="nav-section-label">
                    <VBox.margin><Insets top="16" bottom="2"/></VBox.margin>
                </Label>
                <Button fx:id="navVendors"
                        text="  🍔   Vendor Hub"
                        styleClass="nav-btn"
                        maxWidth="Infinity"
                        onAction="#showVendors"/>
            </VBox>

            <!-- Bottom: admin info + logout -->
            <Separator styleClass="sidebar-divider"/>
            <VBox styleClass="sidebar-footer" spacing="8">
                <padding><Insets top="12" right="16" bottom="8" left="16"/></padding>
                <Label fx:id="adminNameLabel" text="Admin" styleClass="sidebar-admin-name"/>
                <Label fx:id="adminEmailLabel" text="" styleClass="sidebar-admin-email"/>
                <Button text="Sign Out"
                        styleClass="btn-logout"
                        maxWidth="Infinity"
                        onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <!-- ── MAIN CONTENT AREA ──────────────────────────────────────────────── -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <!-- Content is loaded dynamically by MainController -->
        </StackPane>
    </center>

</BorderPane>
