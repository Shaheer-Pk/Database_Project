<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.amusementpark.DashboardController"
      styleClass="view-container"
      spacing="24">
    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

    <!-- ── Page header ─────────────────────────────────────────────────── -->
    <VBox spacing="4">
        <Label text="Dashboard" styleClass="page-title"/>
        <Label text="Real-time overview of park operations and revenue" styleClass="page-subtitle"/>
    </VBox>

    <!-- ── Stat Cards Row ──────────────────────────────────────────────── -->
    <HBox spacing="16">
        <!-- Total Revenue -->
        <VBox styleClass="stat-card, stat-card-green" HBox.hgrow="ALWAYS" spacing="8">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="TOTAL REVENUE" styleClass="stat-card-label"/>
            <Label fx:id="totalRevenueLabel" text="PKR 0.00" styleClass="stat-card-value"/>
            <Label text="All payment sources combined" styleClass="stat-card-sub"/>
        </VBox>

        <!-- Active Rides -->
        <VBox styleClass="stat-card, stat-card-blue" HBox.hgrow="ALWAYS" spacing="8">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="ACTIVE RIDES" styleClass="stat-card-label"/>
            <Label fx:id="activeRidesLabel" text="0" styleClass="stat-card-value"/>
            <Label text="Currently operational" styleClass="stat-card-sub"/>
        </VBox>

        <!-- Total Staff -->
        <VBox styleClass="stat-card, stat-card-purple" HBox.hgrow="ALWAYS" spacing="8">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="TOTAL STAFF" styleClass="stat-card-label"/>
            <Label fx:id="staffCountLabel" text="0" styleClass="stat-card-value"/>
            <Label text="Across all departments" styleClass="stat-card-sub"/>
        </VBox>

        <!-- Total Customers -->
        <VBox styleClass="stat-card, stat-card-orange" HBox.hgrow="ALWAYS" spacing="8">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="CUSTOMERS" styleClass="stat-card-label"/>
            <Label fx:id="customerCountLabel" text="0" styleClass="stat-card-value"/>
            <Label text="Registered in system" styleClass="stat-card-sub"/>
        </VBox>
    </HBox>

    <!-- ── Revenue Breakdown ───────────────────────────────────────────── -->
    <VBox styleClass="card" spacing="16">
        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
        <Label text="Revenue Breakdown" styleClass="card-title"/>

        <GridPane hgap="16" vgap="12">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
            </columnConstraints>

            <!-- Ride Revenue -->
            <VBox styleClass="revenue-item" GridPane.columnIndex="0" spacing="6">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <Label text="🎢  Rides" styleClass="revenue-item-label"/>
                <Label fx:id="rideRevenueLabel" text="PKR 0.00" styleClass="revenue-item-value"/>
            </VBox>

            <!-- Cinema Revenue -->
            <VBox styleClass="revenue-item" GridPane.columnIndex="1" spacing="6">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <Label text="🎬  Cinema" styleClass="revenue-item-label"/>
                <Label fx:id="cinemaRevenueLabel" text="PKR 0.00" styleClass="revenue-item-value"/>
            </VBox>

            <!-- Bowling Revenue -->
            <VBox styleClass="revenue-item" GridPane.columnIndex="2" spacing="6">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <Label text="🎳  Bowling" styleClass="revenue-item-label"/>
                <Label fx:id="bowlingRevenueLabel" text="PKR 0.00" styleClass="revenue-item-value"/>
            </VBox>

            <!-- Food Revenue -->
            <VBox styleClass="revenue-item" GridPane.columnIndex="3" spacing="6">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <Label text="🍔  Food Stalls" styleClass="revenue-item-label"/>
                <Label fx:id="foodRevenueLabel" text="PKR 0.00" styleClass="revenue-item-value"/>
            </VBox>
        </GridPane>
    </VBox>

    <!-- ── Vendor + Food Stall count ──────────────────────────────────── -->
    <HBox spacing="16">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="8">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="ACTIVE FOOD STALLS" styleClass="stat-card-label"/>
            <Label fx:id="foodStallCountLabel" text="0" styleClass="stat-card-value"/>
        </VBox>

        <!-- Refresh button -->
        <VBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
            <Button text="↻  Refresh Stats"
                    styleClass="btn-secondary"
                    onAction="#refreshStats"/>
        </VBox>
    </HBox>

</VBox>
