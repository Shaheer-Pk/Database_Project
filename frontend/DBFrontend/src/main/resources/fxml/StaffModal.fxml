<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
  StaffModal.fxml — used for BOTH Add and Edit.
  The controller sets the title and pre-fills fields for Edit mode.
  Loaded into a Dialog<Staff> by StaffController.
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.amusementpark.StaffModalController"
      styleClass="modal-body"
      spacing="0"
      prefWidth="480">

    <!-- Modal header -->
    <VBox styleClass="modal-header" spacing="4">
        <padding><Insets top="24" right="24" bottom="20" left="24"/></padding>
        <Label fx:id="modalTitle" text="Add Staff Member" styleClass="modal-title"/>
        <Label fx:id="modalSubtitle" text="Fill in all fields below" styleClass="modal-subtitle"/>
    </VBox>

    <Separator/>

    <!-- Form fields -->
    <VBox spacing="14" style="-fx-padding: 24;">

        <!-- Row 1: First Name + Last Name -->
        <HBox spacing="12">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="First Name *" styleClass="field-label"/>
                <TextField fx:id="firstNameField"
                           promptText="e.g. Ahmed"
                           styleClass="text-field-flat"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Last Name *" styleClass="field-label"/>
                <TextField fx:id="lastNameField"
                           promptText="e.g. Khan"
                           styleClass="text-field-flat"/>
            </VBox>
        </HBox>

        <!-- Title -->
        <VBox spacing="5">
            <Label text="Job Title *" styleClass="field-label"/>
            <TextField fx:id="titleField"
                       promptText="e.g. Ride Operator"
                       styleClass="text-field-flat"/>
        </VBox>

        <!-- Email -->
        <VBox spacing="5">
            <Label text="Email Address *" styleClass="field-label"/>
            <TextField fx:id="emailField"
                       promptText="e.g. ahmed@apexpark.com"
                       styleClass="text-field-flat"/>
        </VBox>

        <!-- Row 2: Phone + Salary -->
        <HBox spacing="12">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Phone Number" styleClass="field-label"/>
                <TextField fx:id="phoneField"
                           promptText="+92 300 0000000"
                           styleClass="text-field-flat"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Salary (PKR) *" styleClass="field-label"/>
                <TextField fx:id="salaryField"
                           promptText="e.g. 45000"
                           styleClass="text-field-flat"/>
            </VBox>
        </HBox>

        <!-- Reports To -->
        <VBox spacing="5">
            <Label text="Reports To (Manager)" styleClass="field-label"/>
            <ComboBox fx:id="reportsToCombo"
                      promptText="— None (Top-level) —"
                      styleClass="combo-flat"
                      maxWidth="Infinity"/>
        </VBox>

        <!-- Validation error -->
        <Label fx:id="validationLabel"
               text=""
               styleClass="error-label"
               wrapText="true"/>
    </VBox>

    <Separator/>

    <!-- Modal footer actions -->
    <HBox styleClass="modal-footer" alignment="CENTER_RIGHT" spacing="10">
        <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
        <Button fx:id="cancelButton"
                text="Cancel"
                styleClass="btn-secondary"
                onAction="#handleCancel"/>
        <Button fx:id="saveButton"
                text="Save Staff Member"
                styleClass="btn-primary"
                onAction="#handleSave"
                defaultButton="true"/>
    </HBox>

</VBox>
