<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.amusementpark.LoginController"
           styleClass="root-pane">

    <!-- Split: left brand panel + right form panel -->
    <HBox>

        <!-- ── LEFT: Brand Panel ───────────────────────────────────────── -->
        <VBox styleClass="login-brand-panel" alignment="CENTER" HBox.hgrow="ALWAYS">
            <Label text="🎡" styleClass="login-brand-icon"/>
            <Label text="APEX PARK" styleClass="login-brand-title"/>
            <Label text="Admin Console" styleClass="login-brand-subtitle"/>
            <Label text="Manage everything. Know everything." styleClass="login-brand-tagline"/>
        </VBox>

        <!-- ── RIGHT: Form Panel ───────────────────────────────────────── -->
        <VBox styleClass="login-form-panel" alignment="CENTER" HBox.hgrow="ALWAYS">
            <VBox styleClass="login-card" alignment="CENTER_LEFT">
                <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>
                <VBox.margin><Insets/></VBox.margin>

                <Label text="Welcome back" styleClass="login-heading"/>
                <Label text="Sign in to your admin account" styleClass="login-subheading"/>

                <VBox spacing="6" style="-fx-padding: 28 0 0 0;">
                    <Label text="Email address" styleClass="field-label"/>
                    <TextField fx:id="emailField"
                               promptText="admin@apexpark.com"
                               styleClass="text-field-flat"/>
                </VBox>

                <VBox spacing="6" style="-fx-padding: 18 0 0 0;">
                    <Label text="Password" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField"
                                  promptText="••••••••"
                                  styleClass="text-field-flat"/>
                </VBox>

                <Label fx:id="errorLabel"
                       text=""
                       styleClass="error-label"
                       wrapText="true"
                       style="-fx-padding: 12 0 0 0;"/>

                <Button fx:id="loginButton"
                        text="Sign In"
                        styleClass="btn-primary"
                        maxWidth="Infinity"
                        onAction="#handleLogin"
                        style="-fx-padding: 14 0 14 0; -fx-font-size: 14px; -fx-cursor: hand;"
                        defaultButton="true">
                    <VBox.margin><Insets top="24"/></VBox.margin>
                </Button>

                <Label fx:id="versionLabel"
                       text="Apex Park Management System v1.0"
                       styleClass="login-version"
                       style="-fx-padding: 32 0 0 0;"/>
            </VBox>
        </VBox>

    </HBox>
</StackPane>
