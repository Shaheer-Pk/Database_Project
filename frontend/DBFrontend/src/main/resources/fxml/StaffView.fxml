<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.cell.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.amusementpark.StaffController"
      styleClass="view-container"
      spacing="20">
    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

    <!-- ── Page Header ─────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label text="Staff Management" styleClass="page-title"/>
            <Label text="Add, edit, and manage all park employees" styleClass="page-subtitle"/>
        </VBox>
        <Button text="+ Add Staff"
                styleClass="btn-primary"
                onAction="#handleAdd"/>
    </HBox>

    <!-- ── Search + Filter Bar ─────────────────────────────────────────── -->
    <HBox styleClass="toolbar" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
        <TextField fx:id="searchField"
                   promptText="Search by name or title..."
                   styleClass="text-field-flat"
                   prefWidth="300"
                   onKeyReleased="#handleSearch"/>
        <Button text="Search" styleClass="btn-secondary" onAction="#handleSearch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="recordCountLabel" text="0 records" styleClass="record-count-label"/>
    </HBox>

    <!-- ── Staff TableView ─────────────────────────────────────────────── -->
    <TableView fx:id="staffTable"
               styleClass="flat-table"
               VBox.vgrow="ALWAYS">

        <columns>
            <TableColumn fx:id="colId"        text="ID"          prefWidth="60"  style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colFirstName" text="First Name"  prefWidth="130"/>
            <TableColumn fx:id="colLastName"  text="Last Name"   prefWidth="130"/>
            <TableColumn fx:id="colTitle"     text="Title"       prefWidth="180"/>
            <TableColumn fx:id="colEmail"     text="Email"       prefWidth="200"/>
            <TableColumn fx:id="colPhone"     text="Phone"       prefWidth="130"/>
            <TableColumn fx:id="colSalary"    text="Salary (PKR)" prefWidth="120" style="-fx-alignment: CENTER_RIGHT;"/>
            <TableColumn fx:id="colReportsTo" text="Reports To"  prefWidth="110" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colActions"   text="Actions"     prefWidth="140" style="-fx-alignment: CENTER;" sortable="false"/>
        </columns>

        <!-- Empty state -->
        <placeholder>
            <Label text="No staff found. Click '+ Add Staff' to get started."
                   styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

</VBox>
